      "expected_state": "CONTACT_CAPTURE",
      "expected_missing_fields": [
        "contact"
      ],
      "expected_fields": {
        "car_model": "Toyota Camry",
        "budget": "3000000",
        "purchase_type": "кредит",
        "contact": null
