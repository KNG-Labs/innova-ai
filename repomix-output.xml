## 7. Хранилища данных

```mermaid
graph TB
    subgraph pg["PostgreSQL — Основная база данных"]
        pg1["Клиенты и их настройки"]
        pg2["Сессии и история диалогов"]
        pg3["Лиды и история доставки"]
    end

    subgraph redis["Redis — Быстрый кэш и очередь"]
        r1["Активные сессии (живут часы)"]
        r2["Rate limiting по клиенту"]
        r3["Очередь задач на доставку"]
    end

    subgraph vector["Векторное хранилище — База знаний клиентов"]
        v1["Эмбеддинги чанков сайта"]
        v2["Пространства по tenant_id"]
        v3["Семантический поиск (RAG)"]
    end

    subgraph s3["Объектное хранилище — Сырые файлы и логи"]
        s3_1["Просканированные страницы"]
