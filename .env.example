# ── LLM ──────────────────────────────────────────────────────────────────────
# stub  — FakeAg2AgentClient, без LLM key (локальная разработка и тесты)
# ag2   — реальный AG2 через OpenRouter
LLM_PROVIDER=stub

# AG2 через OpenRouter (нужно только если LLM_PROVIDER=ag2)
OPENROUTER_API_KEY=sk-or-v1-your-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AG2_MODEL=openai/gpt-4o-mini

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://innova:innova@localhost:5432/innova_ai

# ── Redis ─────────────────────────────────────────────────────────────────────
# Нужен для очереди доставки лидов (Phase 5)
REDIS_URL=redis://localhost:6379/0

# ── Vector store ──────────────────────────────────────────────────────────────
# pgvector  — расширение PostgreSQL (проще для MVP)
# qdrant    — отдельный сервис
# VECTOR_STORE=pgvector

# ── CRM ───────────────────────────────────────────────────────────────────────
# AmoCRM — первая обязательная интеграция MVP
# AMOCRM_BASE_URL=https://your-domain.amocrm.ru
# AMOCRM_ACCESS_TOKEN=your-token

# Битрикс24 — вторая интеграция (допускается как second adapter)
# BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/1/your-key/

# LEAD_DELIVERY_PROVIDER=disabled   # disabled|fake|amocrm|bitrix24|webhook
# LEAD_WEBHOOK_URL=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=