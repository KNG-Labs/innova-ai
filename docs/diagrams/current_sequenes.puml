@startuml sequence_current
skinparam shadowing false
skinparam defaultFontName Arial
skinparam sequenceArrowThickness 1.5
skinparam sequenceLifeLineBorderColor #888888
skinparam sequenceParticipantBorderColor #555555
skinparam sequenceParticipantBackgroundColor #FAFAFA
skinparam noteBackgroundColor #FFFDE7
skinparam noteBorderColor #CCBB55

title Innova AI — Текущая реализация\nPOST /message и read-routes

actor "Пользователь" as User
participant "Сайт / Telegram / Avito" as Channel
participant "MessageRouter" as Router
participant "AgentService" as Agent
participant "UserRepository" as Users
participant "DialogSessionRepository" as Sessions
participant "MessageRepository" as Messages
participant "IntentDetector\n(keyword)" as Intent
participant "LLMClient\n(stub / OpenRouter)" as LLM
database "PostgreSQL\n(AsyncSession)" as PG

== POST /message — happy path ==

User -> Channel : сообщение
Channel -> Router : POST /message\n{anonymous_id, channel, content, session_id?}
Router -> Agent : handle_message(request)

note right of Agent
  1. Нормализация текста
  2. Определение intent (keyword)
  3. Вычисление next_step
end note

Agent -> Users : get_or_create_anonymous_user\n(channel, anonymous_id)
Users -> PG : SELECT user WHERE\nchannel=? AND anonymous_id=?
PG --> Users : user | None

alt user не найден
    Users -> PG : INSERT user
    PG --> Users : user (new id)
end
Users --> Agent : user

Agent -> Sessions : get_or_create_active_session\n(user_id, session_id?)

alt передан session_id
    Sessions -> PG : SELECT session WHERE id=?
    PG --> Sessions : existing_session | None

    alt session найдена
        note right of Sessions #FFE0E0
          ПРОВЕРКА ВЛАДЕНИЯ:
          existing_session.user_id != user_id
          → SessionOwnershipError
        end note
        Sessions --> Agent : existing_session
    else session не найдена
        note right of Sessions : fallback ниже
    end
end

alt нет активной сессии
    Sessions -> PG : SELECT session WHERE\nuser_id=? AND closed_at IS NULL\nORDER BY created_at DESC LIMIT 1
    PG --> Sessions : active_session | None

    alt активная не найдена
        Sessions -> PG : INSERT dialog_session\n(state='GREETING')
        PG --> Sessions : new_session
    end
end

Sessions --> Agent : dialog_session

Agent -> Messages : create(session_id, role='user',\ncontent, metadata={intent, next_step})
Messages -> PG : INSERT message
PG --> Messages : user_message

Agent -> Messages : list_by_session_id(session_id)\n[LIMIT 20]
Messages -> PG : SELECT messages\nWHERE session_id=?\nORDER BY created_at ASC
PG --> Messages : history

Agent -> Intent : detect(last_user_message)
Intent --> Agent : intent ∈ {pricing,\nlead_request, support, general}

Agent -> Agent : _build_llm_request(history)\n→ ChatCompletionRequest

alt LLM_PROVIDER=stub
    Agent -> LLM : create_chat_completion(request)
    LLM --> Agent : "Здравствуйте! Чем могу помочь?"
else LLM_PROVIDER=openrouter
    Agent -> LLM : create_chat_completion(request)
    LLM -> LLM : OpenAI SDK → OpenRouter API
    LLM --> Agent : ChatCompletionResponse
end

Agent -> Agent : _extract_answer(response)

Agent -> Messages : create(session_id, role='assistant',\ncontent, metadata)
Messages -> PG : INSERT message
PG --> Messages : assistant_message

Agent -> PG : COMMIT
PG --> Agent : ok

Agent --> Router : AgentMessageResponse\n{user_id, session_id,\nuser_message_id, assistant_message_id,\nanswer, state, intent, next_step}

alt SessionOwnershipError (чужой session_id)
    Router --> Channel : HTTP 403\n"Session does not belong to user"
else ok
    Router --> Channel : HTTP 200 + JSON
end

Channel --> User : показать ответ

== GET /sessions/{session_id} ==

User -> Channel : хочу проверить состояние
Channel -> Router : GET /sessions/{session_id}
Router -> Router : SessionService.get_session(session_id)
Router -> Sessions : get_by_id_with_user(session_id)
Sessions -> PG : SELECT session\nJOIN user WHERE id=?
PG --> Sessions : session | None

alt session не найдена
    Router --> Channel : HTTP 404\n"Session not found"
else найдена
    Router --> Channel : SessionResponse\n{id, user_id, state,\nchannel, created_at, updated_at}
end

Channel --> User : показать состояние

== GET /sessions/{session_id}/messages ==

User -> Channel : хочу посмотреть историю
Channel -> Router : GET /sessions/{session_id}/messages
Router -> Router : SessionService.get_session_messages(session_id)
Router -> Sessions : get_by_id(session_id)
Sessions -> PG : SELECT session WHERE id=?
PG --> Sessions : session | None

alt session не найдена
    Router --> Channel : HTTP 404 "Session not found"
else найдена
    Router -> Messages : list_by_session_id(session_id)
    Messages -> PG : SELECT messages\nWHERE session_id=?\nORDER BY created_at ASC
    PG --> Messages : messages
    Router --> Channel : [StoredMessageResponse]\n{id, session_id, role,\ncontent, created_at}
end

Channel --> User : показать историю

note over PG, LLM
  Что пока НЕ реализовано
  (есть в Sequence.puml / System_Design):
  — state machine переходы (GREETING→FAQ→...)
  — qualification_data
  — Lead Builder и сборка карточки лида
  — Redis (кэш сессий, очередь)
  — Knowledge Base / RAG
  — асинхронная доставка в CRM / Telegram
  — multi-tenancy (tenant_id)
end note

@enduml