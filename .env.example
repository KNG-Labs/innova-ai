# LLM: stub для локального детерминированного режима, ag2 для OpenRouter.
LLM_PROVIDER=stub
OPENROUTER_API_KEY=sk-or-v1-your-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AG2_MODEL=openai/gpt-oss-120B:free

# URL базы для запуска на хосте. Docker Compose переопределяет адрес внутри контейнеров.
DATABASE_URL=postgresql+asyncpg://innova:innova@localhost:5433/innova_ai

# Разрешённые browser origins через запятую.
# Вне локальной разработки перечислите конкретные домены дилера.
CORS_ALLOW_ORIGINS=*

# Redis-очередь доставки лидов.
REDIS_URL=redis://localhost:6379/0

# Embeddings: fake для разработки и тестов, openrouter для внешней модели.
EMBEDDING_PROVIDER=fake
# Выбранная модель должна возвращать векторы размерности 1536.
# EMBEDDING_MODEL=openai/text-embedding-3-small

# Доставка лидов: disabled | fake | amocrm | webhook
LEAD_DELIVERY_PROVIDER=disabled

# Обязательно при LEAD_DELIVERY_PROVIDER=amocrm.
AMOCRM_BASE_URL=https://your-domain.amocrm.ru
AMOCRM_ACCESS_TOKEN=your-token

# Обязательно при LEAD_DELIVERY_PROVIDER=webhook.
# LEAD_WEBHOOK_URL=https://example.com/lead-webhook
