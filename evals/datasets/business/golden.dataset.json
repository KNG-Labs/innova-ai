      "expected_behavior": "answer_only",
      "expected_max_questions": 0,
      "expected_intent": "unknown",
      "expected_state": "FAQ",
      "expected_missing_fields": [
        "car_model",
        "budget",
        "purchase_type",
        "contact"
      ],
      "expected_fields": {
        "car_model": null,
        "budget": null,
        "purchase_type": null,
        "contact": null
      }
    },
