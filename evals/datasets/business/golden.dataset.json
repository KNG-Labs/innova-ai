{
  "schema_version": "2.0",
  "name": "innova_business_regression_v2",
  "evaluation_type": "business",
  "description": "End-to-end dialogue state, extraction, opt-out, FAQ and sparse-patch regressions.",
  "cases": [
    {
      "id": "biz_lead_qualification_001",
      "split": "regression",
      "category": "lead_qualification",
      "question": "Ищу Toyota Camry до 3 миллионов, хочу купить в кредит.",
      "expected_behavior": "answer_before_qualification",
      "expected_max_questions": 1,
      "expected_intent": "lead_request",
      "expected_state": "CONTACT_CAPTURE",
      "expected_missing_fields": [
        "contact"
      ],
      "expected_fields": {
        "car_model": "Toyota Camry",
        "budget": "3000000",
        "purchase_type": "кредит",
        "contact": null
      }
    },
    {
      "id": "biz_lead_trade_in_001",
      "split": "regression",
      "category": "lead_qualification",
      "question": "Хочу Kia Rio за 2 миллиона сдать свою машину в trade-in.",
      "expected_behavior": "answer_before_qualification",
      "expected_max_questions": 1,
      "expected_intent": "lead_request",
      "expected_state": "CONTACT_CAPTURE",
      "expected_missing_fields": [
        "contact"
      ],
      "expected_fields": {
        "car_model": "Kia Rio",
        "budget": "2000000",
        "purchase_type": "trade-in",
        "contact": null
      }
    },
    {
      "id": "biz_contact_phone_001",
      "split": "regression",
      "category": "contact_capture",
      "setup_messages": [
        "Ищу Toyota Camry до 3 миллионов, хочу купить в кредит."
      ],
      "question": "Мой телефон +7 999 123-45-67.",
      "expected_behavior": "answer_only",
      "expected_max_questions": 0,
      "expected_intent": "lead_request",
      "expected_state": "LEAD_READY",
      "expected_missing_fields": [],
      "expected_fields": {
        "car_model": "Toyota Camry",
        "budget": "3000000",
        "purchase_type": "кредит",
        "contact": "+7 999 123-45-67"
      }
    },
    {
